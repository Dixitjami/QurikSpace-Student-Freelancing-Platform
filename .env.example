# Local example only. Use your hosting provider's secret manager in production.
DEBUG=0
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=your-domain.example.com
CSRF_TRUSTED_ORIGINS=https://your-domain.example.com
DATABASE_URL=postgresql://user:password@database-host:5432/database-name
PORT=8000

# Set to 0 only when HTTPS is terminated somewhere that does not forward
# X-Forwarded-Proto. Production deployments should normally keep these enabled.
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000

